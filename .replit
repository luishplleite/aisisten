modules = ["web", "nodejs-20", "bash"]

[nix]
channel = "stable-25_05"
packages = ["jq"]

[agent]
expertMode = true
integrations = ["javascript_supabase:1.0.0", "javascript_openai:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "TimePulse AI Server"

[[workflows.workflow]]
name = "TimePulse AI Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm start"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 36523
externalPort = 3001

[[ports]]
localPort = 37987
externalPort = 3003

[[ports]]
localPort = 44325
externalPort = 4200

[[ports]]
localPort = 44609
externalPort = 3000

[[ports]]
localPort = 46711
externalPort = 3002

[deployment]
deploymentTarget = "autoscale"
run = ["node", "server.js"]
